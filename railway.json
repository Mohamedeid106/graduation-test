{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python core/manage.py collectstatic --noinput"
  },
  "deploy": {
    "preDeployCommand": "python core/manage.py migrate",
    "startCommand": "cd core && gunicorn core.wsgi:application --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
